<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>HextechRunes</AssemblyName>
    <RootNamespace>HextechRunes</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GameRoot>/Users/iniad/Library/Application Support/Steam/steamapps/common/Slay the Spire 2/SlayTheSpire2.app</GameRoot>
    <OfficialGameDataDir>$(MSBuildThisFileDirectory)../versioned-dll-backups/0.103.3/game-refs</OfficialGameDataDir>
    <GameDataDir Condition="'$(GameDataDir)' == '' and Exists('$(OfficialGameDataDir)/sts2.dll')">$(OfficialGameDataDir)</GameDataDir>
    <GameDataDir Condition="'$(GameDataDir)' == ''">$(GameRoot)/Contents/Resources/data_sts2_macos_arm64</GameDataDir>
    <HextechSts2Target Condition="'$(HextechSts2Target)' == ''">0.103.3</HextechSts2Target>
  </PropertyGroup>

  <PropertyGroup Condition="'$(HextechSts2Target)' == '0.103.2'">
    <DefineConstants>$(DefineConstants);STS2_103_2</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(HextechSts2Target)' == '0.104.0'">
    <DefineConstants>$(DefineConstants);STS2_104_OR_NEWER</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(HextechSts2Target)' == '0.105.1'">
    <DefineConstants>$(DefineConstants);STS2_104_OR_NEWER;STS2_105_OR_NEWER</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(HextechSts2Target)' == '0.106.1'">
    <DefineConstants>$(DefineConstants);STS2_104_OR_NEWER;STS2_105_OR_NEWER;STS2_106_OR_NEWER</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition="'$(HextechSts2Target)' == '0.107.0'">
    <DefineConstants>$(DefineConstants);STS2_104_OR_NEWER;STS2_105_OR_NEWER;STS2_106_OR_NEWER;STS2_107_OR_NEWER</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="sts2">
      <HintPath>$(GameDataDir)/sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GodotSharp">
      <HintPath>$(GameDataDir)/GodotSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(GameDataDir)/0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
